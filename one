import tkinter as tk
import random
import threading
import time
def dow():
    w = tk.Tk()
    w.title('xxx')
    w.geometry(f'220x50+{random.randrange(0, w.winfo_screenwidth())}+{random.randrange(0, w.winfo_screenheight())}')
    tk.Label(w, text='生日快乐!', bg='pink', font=('楷体', 18), width=25, height=4).pack()
    w.mainloop()
for i in range(100):
    threading.Thread(target=dow).start()
    time.sleep(0.01)
